# Claude Fleet configuration (.env format).
# Copy to ~/.claude-fleet/.env (the default), or point at it with --config/-c.
# Every value is optional; real environment variables override what's here.

# --- Paths ---
# FLEET_ROOT=~/.claude-fleet/instances     # per-instance clones
# FLEET_DB=~/.claude-fleet/fleet.db         # SQLite state file
# FLEET_SECRETS=~/.claude-fleet/secrets     # per-instance git credential files

# --- Secrets / auth ---
# Fernet key that encrypts stored GitLab credentials. Generate: python crypto.py
# FLEET_SECRET_KEY=
# If set, every request must carry this value in the X-Auth-Token header.
# FLEET_AUTH_TOKEN=

# --- Claude / remote-control ---
# CLAUDE_RC_CMD=claude remote-control
# RELAY_REGEX=https?://\S+

# --- Server ---
# FLEET_HOST=127.0.0.1     # keep loopback in production; front it with a proxy
# FLEET_PORT=8700
